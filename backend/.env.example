# ─── OX Arena backend configuration ───────────────────────────────────────────
# Copy to `.env`. Every value below has a safe local default, so an empty .env
# still boots the server in dev mode (in-memory Redis shim, persistence disabled).

# HTTP / WS port
PORT=8080

# Node environment: development | production
NODE_ENV=development

# Secret used to sign anonymous session JWTs. CHANGE THIS IN PRODUCTION.
JWT_SECRET=dev-insecure-secret-change-me

# Anonymous session token lifetime (seconds). Default 7 days.
JWT_TTL_SECONDS=604800

# Comma-separated allowed CORS origins. "*" allows all (fine for a public game API).
CORS_ORIGIN=*

# ─── Optional infrastructure ─────────────────────────────────────────────────
# Leave BLANK for local dev — the server uses an in-memory Redis shim and skips
# Postgres persistence. Set these (Render injects them automatically) for real infra.

# e.g. redis://default:password@host:6379
REDIS_URL=

# e.g. postgres://user:password@host:5432/oxarena
DATABASE_URL=

# Reconnect grace window (ms) a disconnected player has to rejoin their match.
RECONNECT_GRACE_MS=15000

# Matchmaking: max time (ms) a player waits before the queue times out.
QUEUE_TIMEOUT_MS=60000
