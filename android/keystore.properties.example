# Release signing configuration — copy to `keystore.properties` (gitignored).
#
# Generate a keystore with:
#   keytool -genkeypair -v -keystore keystore/oxarena-release.keystore \
#     -alias oxarena -keyalg RSA -keysize 2048 -validity 10000
#
# ⚠ BACK UP the keystore and passwords somewhere safe (password manager).
#   Losing them means you can never update the app under the same signature.

storeFile=keystore/oxarena-release.keystore
storePassword=CHANGE_ME
keyAlias=oxarena
keyPassword=CHANGE_ME
